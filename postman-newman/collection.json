  "item": [
    {
      "name": "Creating a Duplicate Repository",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verify the status code of the duplicate repository request.\r",
              "pm.test(\"Verify the status code of the duplicate repository request\",function(){\r",
              "    pm.expect(pm.response.code).to.eql(422);\r",
              "});\r",
              "\r",
              "//Verify status message contains unprocessable entity\r",
              "pm.test(\"Verify status message contains unprocessable entity\",function(){\r",
              "    pm.expect(pm.response.status).to.include(\"Unprocessable Entity (WebDAV) (RFC 4918)\");\r",
              "});\r",
              "\r",
              "//Verify the response time is below 2 seconds\r",
              "pm.test(\"Response time is below 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "//Verify response body contains message \"repository creation failed\".\r",
              "pm.test(\"Verify the response body contains the correct message\", function () { \r",
              "    let body = pm.response.json(); \r",
              "    pm.expect(body.message).to.include(\"Repository creation failed.\");\r",
              "});\r",
              "\r",
              "//Verify response body contains the error message \"repository creation failed\".\r",
              "pm.test(\"Verify the response body contains the correct error message\", function () { let body = pm.response.json();\r",
              "    pm.expect(body.errors[0].message).to.include(\"name already exists on this account\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/vnd.github+json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "{{TOKEN}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"Assignments\",\r\n    \"description\":\"Sample Duplicate Repo From Postman\",\r\n    \"private\": true\r\n    \r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/user/repos",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
    },
    {
