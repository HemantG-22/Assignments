      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verify the status code of the Valid repository request.\r",
              "pm.test(\"Verify the status code of the Valid repository request\",function(){\r",
              "    pm.expect(pm.response.code).to.eql(201);\r",
              "});\r",
              "\r",
              "//Verify status message contains unprocessable entity\r",
              "pm.test(\"Verify the status code of the Valid repository request\",function(){\r",
              "    pm.expect(pm.response.status).to.include(\"Created\");\r",
              "});\r",
              "\r",
              "//Verify the response time is below 2 seconds\r",
              "pm.test(\"Response time is below 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "//Verify response body contains message \"repository creation failed\".\r",
              "pm.test(\"Verify the response body contains the correct message\", function () { \r",
              "    let body = pm.response.json(); \r",
              "    pm.expect(body.name).to.include(\"AssignmentsAPI1\");\r",
              "});\r",
              "\r",
              "//Verify response body contains the privet true\r",
              "pm.test(\"Verify the response body contains the correct message\", function () { let body = pm.response.json();\r",
              "    pm.expect(body.private).to.include(true);\r",
              "});"
